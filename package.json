{
    "name":  "vtest",
    "version":  "0.1.0",
    "description":  "AI-powered Android App Testing Tool",
    "private":  true,
    "type":  "module",
    "main":  "dist/main/index.js",
    "pnpm":  {
                 "workspaces":  [
                                    ".",
                                    ".wolf/hooks"
                                ]
             },
    "scripts":  {
                    "dev":  "electron-vite dev",
                    "build":  "electron-vite build",
                    "preview":  "electron-vite preview",
                    "lint":  "eslint . --ext .ts,.tsx",
                    "test":  "jest --testPathIgnorePatterns=\u0027integration|e2e\u0027 \u0026\u0026 vitest run",
                    "test:unit":  "jest --testPathIgnorePatterns=\u0027integration|e2e\u0027 \u0026\u0026 vitest run",
                    "test:integration":  "jest --testPathPattern=integration",
                    "test:e2e":  "jest --testPathPattern=e2e",
                    "migrate:latest":  "knex migrate:latest",
                    "migrate:rollback":  "knex migrate:rollback"
                },
    "dependencies":  {
                         "better-sqlite3":  "^11.0.0",
                         "knex":  "^3.1.0",
                         "react":  "^18.2.0",
                         "react-dom":  "^18.2.0",
                         "uuid":  "^14.0.0"
                     },
    "devDependencies":  {
                            "@types/better-sqlite3":  "^7.6.9",
                            "@types/jest":  "^29.5.0",
                            "@types/node":  "^20.11.0",
                            "@types/react":  "^18.2.0",
                            "@types/react-dom":  "^18.2.0",
                            "@types/uuid":  "^9.0.0",
                            "@typescript-eslint/eslint-plugin":  "^6.19.0",
                            "@typescript-eslint/parser":  "^6.19.0",
                            "@vitest/coverage-v8":  "^4.1.9",
                            "electron":  "^33.0.0",
                            "electron-vite":  "^2.3.0",
                            "eslint":  "^8.57.0",
                            "jest":  "^29.7.0",
                            "sqlite3":  "^6.0.1",
                            "tailwindcss":  "^3.4.1",
                            "ts-jest":  "^29.1.0",
                            "typescript":  "^5.3.3",
                            "vite":  "^5.0.12",
                            "vitest":  "^4.1.9"
                        }
}